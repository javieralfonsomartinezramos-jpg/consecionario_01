<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.prueba.adminPanelController"
           style="-fx-background-color: linear-gradient(to bottom right, #080808, #121212, #191919);">

    <children>

        <BorderPane style="-fx-background-color: transparent;">

            <top>
                <HBox alignment="CENTER_LEFT"
                      spacing="18"
                      style="-fx-background-color: rgba(18,18,18,0.96);
                             -fx-padding: 22 35 22 35;
                             -fx-border-color: rgba(245,197,66,0.18);
                             -fx-border-width: 0 0 1 0;">

                    <VBox spacing="4">
                        <Label text="ADMINISTRADOR DE TIENDA"
                               style="-fx-text-fill: #f5c542;
                                      -fx-font-size: 32;
                                      -fx-font-weight: bold;" />

                        <Label text="Gestion del inventario del catalogo"
                               style="-fx-text-fill: #b8b8b8;
                                      -fx-font-size: 14;" />
                    </VBox>

                    <Region HBox.hgrow="ALWAYS" />

                    <Button text="VOLVER AL CATALOGO"
                            onAction="#volverCatalogo"
                            style="-fx-background-color: #242424;
                                   -fx-text-fill: #f5c542;
                                   -fx-border-color: #f5c542;
                                   -fx-border-radius: 14;
                                   -fx-background-radius: 14;
                                   -fx-font-size: 14;
                                   -fx-font-weight: bold;
                                   -fx-padding: 12 22 12 22;
                                   -fx-cursor: hand;" />
                </HBox>
            </top>

            <center>
                <HBox alignment="CENTER"
                      spacing="28"
                      style="-fx-padding: 32;">

                    <VBox alignment="TOP_CENTER"
                          spacing="15"
                          prefWidth="430"
                          maxWidth="430"
                          style="-fx-background-color: #1c1c1c;
                                 -fx-background-radius: 18;
                                 -fx-border-color: #303030;
                                 -fx-border-radius: 18;
                                 -fx-padding: 26;">

                        <Label text="Datos del producto"
                               style="-fx-text-fill: white;
                                      -fx-font-size: 25;
                                      -fx-font-weight: bold;" />

                        <Label text="Informacion principal del producto"
                               wrapText="true"
                               style="-fx-text-fill: #aaaaaa;
                                      -fx-font-size: 13;" />

                        <VBox alignment="CENTER_LEFT" spacing="6">
                            <Label text="Nombre"
                                   style="-fx-text-fill: #f5c542;
                                          -fx-font-size: 13;
                                          -fx-font-weight: bold;" />

                            <TextField fx:id="txtNombre"
                                       prefHeight="42"
                                       prefWidth="360"
                                       promptText="Ej: Yamaha R6"
                                       style="-fx-background-color: #282828;
                                              -fx-text-fill: white;
                                              -fx-prompt-text-fill: #777777;
                                              -fx-background-radius: 12;
                                              -fx-border-color: #3a3a3a;
                                              -fx-border-radius: 12;
                                              -fx-font-size: 14;" />
                        </VBox>

                        <VBox alignment="CENTER_LEFT" spacing="6">
                            <Label text="Marca"
                                   style="-fx-text-fill: #f5c542;
                                          -fx-font-size: 13;
                                          -fx-font-weight: bold;" />

                            <ComboBox fx:id="comboMarca"
                                      prefHeight="42"
                                      prefWidth="360"
                                      promptText="Selecciona marca"
                                      style="-fx-background-color: #282828;
                                             -fx-background-radius: 12;
                                             -fx-font-size: 14;" />
                        </VBox>

                        <VBox alignment="CENTER_LEFT" spacing="6">
                            <Label text="Cilindraje"
                                   style="-fx-text-fill: #f5c542;
                                          -fx-font-size: 13;
                                          -fx-font-weight: bold;" />

                            <TextField fx:id="txtCc"
                                       prefHeight="42"
                                       prefWidth="360"
                                       promptText="Ej: 600"
                                       style="-fx-background-color: #282828;
                                              -fx-text-fill: white;
                                              -fx-prompt-text-fill: #777777;
                                              -fx-background-radius: 12;
                                              -fx-border-color: #3a3a3a;
                                              -fx-border-radius: 12;
                                              -fx-font-size: 14;" />
                        </VBox>

                        <VBox alignment="CENTER_LEFT" spacing="6">
                            <Label text="Precio"
                                   style="-fx-text-fill: #f5c542;
                                          -fx-font-size: 13;
                                          -fx-font-weight: bold;" />

                            <TextField fx:id="txtPrecio"
                                       prefHeight="42"
                                       prefWidth="360"
                                       promptText="Ej: 15000"
                                       style="-fx-background-color: #282828;
                                              -fx-text-fill: white;
                                              -fx-prompt-text-fill: #777777;
                                              -fx-background-radius: 12;
                                              -fx-border-color: #3a3a3a;
                                              -fx-border-radius: 12;
                                              -fx-font-size: 14;" />
                        </VBox>

                        <VBox alignment="CENTER_LEFT" spacing="6">
                            <Label text="Stock"
                                   style="-fx-text-fill: #f5c542;
                                          -fx-font-size: 13;
                                          -fx-font-weight: bold;" />

                            <TextField fx:id="txtStock"
                                       prefHeight="42"
                                       prefWidth="360"
                                       promptText="Ej: 5"
                                       style="-fx-background-color: #282828;
                                              -fx-text-fill: white;
                                              -fx-prompt-text-fill: #777777;
                                              -fx-background-radius: 12;
                                              -fx-border-color: #3a3a3a;
                                              -fx-border-radius: 12;
                                              -fx-font-size: 14;" />
                        </VBox>

                        <VBox alignment="CENTER_LEFT" spacing="6">
                            <Label text="Imagen"
                                   style="-fx-text-fill: #f5c542;
                                          -fx-font-size: 13;
                                          -fx-font-weight: bold;" />

                            <TextField fx:id="txtImagen"
                                       prefHeight="42"
                                       prefWidth="360"
                                       promptText="Ej: yamaha-r6.png"
                                       style="-fx-background-color: #282828;
                                              -fx-text-fill: white;
                                              -fx-prompt-text-fill: #777777;
                                              -fx-background-radius: 12;
                                              -fx-border-color: #3a3a3a;
                                              -fx-border-radius: 12;
                                              -fx-font-size: 14;" />
                        </VBox>

                        <HBox alignment="CENTER"
                              spacing="12">

                            <Button fx:id="btnGuardar"
                                    text="GUARDAR PRODUCTO"
                                    onAction="#guardarMoto"
                                    prefHeight="46"
                                    prefWidth="190"
                                    style="-fx-background-color: #f5c542;
                                           -fx-text-fill: #111111;
                                           -fx-font-size: 13;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 14;
                                           -fx-cursor: hand;" />

                            <Button text="LIMPIAR"
                                    onAction="#limpiarCamposFormulario"
                                    prefHeight="46"
                                    prefWidth="120"
                                    style="-fx-background-color: #303030;
                                           -fx-text-fill: white;
                                           -fx-font-size: 13;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 14;
                                           -fx-cursor: hand;" />
                        </HBox>

                        <Button text="ELIMINAR SELECCIONADO"
                                onAction="#eliminarMoto"
                                prefHeight="44"
                                prefWidth="320"
                                style="-fx-background-color: #e63946;
                                       -fx-text-fill: white;
                                       -fx-font-size: 13;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 14;
                                       -fx-cursor: hand;" />

                    </VBox>

                    <VBox spacing="16"
                          HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #1c1c1c;
                                 -fx-background-radius: 18;
                                 -fx-border-color: #303030;
                                 -fx-border-radius: 18;
                                 -fx-padding: 24;">

                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="4">
                                <Label text="Productos cargados"
                                       style="-fx-text-fill: white;
                                              -fx-font-size: 25;
                                              -fx-font-weight: bold;" />

                                <Label text="Inventario general"
                                       style="-fx-text-fill: #aaaaaa;
                                              -fx-font-size: 13;" />
                            </VBox>
                        </HBox>

                        <TableView fx:id="tablaMotos"
                                   prefHeight="620"
                                   style="-fx-background-color: #242424;
                                          -fx-control-inner-background: #242424;
                                          -fx-table-cell-border-color: #333333;
                                          -fx-text-background-color: white;">

                            <columns>
                                <TableColumn fx:id="colNombre"
                                             text="Nombre"
                                             prefWidth="240" />

                                <TableColumn fx:id="colMarca"
                                             text="Marca"
                                             prefWidth="120" />

                                <TableColumn fx:id="colCc"
                                             text="CC"
                                             prefWidth="80" />

                                <TableColumn fx:id="colPrecio"
                                             text="Precio"
                                             prefWidth="100" />

                                <TableColumn fx:id="colStock"
                                             text="Stock"
                                             prefWidth="80" />

                                <TableColumn fx:id="colImagen"
                                             text="Imagen"
                                             prefWidth="220" />
                            </columns>
                        </TableView>

                    </VBox>

                </HBox>
            </center>

        </BorderPane>

    </children>
</StackPane>
