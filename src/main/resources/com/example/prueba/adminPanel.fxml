<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER"
      spacing="10"
      style="-fx-background-color:#111111; -fx-padding:40;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.prueba.adminPanelController">

    <children>

        <!-- TITULO -->
        <Label text="ADMIN PANEL"
               textFill="#d9ad26">
            <font>
                <Font size="34"/>
            </font>
        </Label>

        <Label text="Agregar nueva moto"
               textFill="white">
            <font>
                <Font size="16"/>
            </font>
        </Label>

        <!-- NOMBRE -->
        <Label text="Nombre"
               textFill="#d9ad26"
               style="-fx-font-size:14px;"/>
        <TextField fx:id="txtNombre"
                   prefWidth="280"
                   prefHeight="35"
                   promptText="Ej: Yamaha R6"/>

        <!-- MARCA -->
        <Label text="Marca"
               textFill="#d9ad26"
               style="-fx-font-size:14px;"/>
        <ComboBox fx:id="comboMarca"
                  prefWidth="280"
                  prefHeight="35"
                  promptText="Selecciona marca"/>

        <!-- CC -->
        <Label text="Cilindraje"
               textFill="#d9ad26"
               style="-fx-font-size:14px;"/>
        <TextField fx:id="txtCc"
                   prefWidth="280"
                   prefHeight="35"
                   promptText="Ej: 600"/>

        <!-- PRECIO -->
        <Label text="Precio"
               textFill="#d9ad26"
               style="-fx-font-size:14px;"/>
        <TextField fx:id="txtPrecio"
                   prefWidth="280"
                   prefHeight="35"
                   promptText="Ej: 15000"/>

        <!-- STOCK -->
        <Label text="Stock"
               textFill="#d9ad26"
               style="-fx-font-size:14px;"/>
        <TextField fx:id="txtStock"
                   prefWidth="280"
                   prefHeight="35"
                   promptText="Ej: 5"/>

        <!-- IMAGEN -->
        <Label text="Imagen"
               textFill="#d9ad26"
               style="-fx-font-size:14px;"/>
        <TextField fx:id="txtImagen"
                   prefWidth="280"
                   prefHeight="35"
                   promptText="Ej: yamaha-r6.png"/>

        <!-- BOTONES -->
        <HBox alignment="CENTER"
              spacing="15">

            <children>

                <Button text="GUARDAR"
                        onAction="#guardarMoto"
                        prefWidth="130"
                        prefHeight="40"
                        style="-fx-background-color:#d9ad26;
                               -fx-background-radius:15;
                               -fx-font-size:16px;" />

                <Button text="CERRAR"
                        onAction="#cerrarVentana"
                        prefWidth="130"
                        prefHeight="40"
                        style="-fx-background-color:#ff4444;
                               -fx-text-fill:white;
                               -fx-background-radius:15;
                               -fx-font-size:16px;" />

            </children>

        </HBox>

    </children>

</VBox>
