<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="900.0"
            prefWidth="1400.0"
            style="-fx-background-color: #121212;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.prueba.DetalleMotoController">

    <children>

        <VBox alignment="CENTER"
              spacing="22.0"
              AnchorPane.topAnchor="25.0"
              AnchorPane.leftAnchor="50.0"
              AnchorPane.rightAnchor="50.0"
              AnchorPane.bottomAnchor="25.0">

            <Label fx:id="lblNombre"
                   text="Nombre de la moto"
                   wrapText="true"
                   maxWidth="1100"
                   alignment="CENTER"
                   style="-fx-text-fill: white;
                          -fx-font-size: 40px;
                          -fx-font-weight: bold;" />

            <HBox alignment="CENTER"
                  spacing="45">

                <StackPane prefWidth="650"
                           prefHeight="420"
                           maxWidth="650"
                           maxHeight="420"
                           style="-fx-background-color: #1e1e1e;
                                  -fx-background-radius: 28;
                                  -fx-padding: 25;
                                  -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.45), 20, 0, 0, 10);">

                    <ImageView fx:id="imgMoto"
                               fitWidth="600"
                               fitHeight="360"
                               preserveRatio="true" />
                </StackPane>

                <VBox alignment="CENTER"
                      spacing="18"
                      prefWidth="430">

                    <VBox alignment="CENTER"
                          spacing="8"
                          prefWidth="390"
                          style="-fx-background-color: #1e1e1e;
                                 -fx-background-radius: 18;
                                 -fx-padding: 22;">

                        <Label text="Marca"
                               style="-fx-text-fill: #aaaaaa;
                                      -fx-font-size: 17px;" />

                        <Label fx:id="lblMarca"
                               text="Marca"
                               wrapText="true"
                               alignment="CENTER"
                               style="-fx-text-fill: white;
                                      -fx-font-size: 25px;
                                      -fx-font-weight: bold;" />
                    </VBox>

                    <VBox alignment="CENTER"
                          spacing="8"
                          prefWidth="390"
                          style="-fx-background-color: #1e1e1e;
                                 -fx-background-radius: 18;
                                 -fx-padding: 22;">

                        <Label text="Cilindraje"
                               style="-fx-text-fill: #aaaaaa;
                                      -fx-font-size: 17px;" />

                        <Label fx:id="lblCc"
                               text="0 CC"
                               style="-fx-text-fill: white;
                                      -fx-font-size: 25px;
                                      -fx-font-weight: bold;" />
                    </VBox>

                    <VBox alignment="CENTER"
                          spacing="8"
                          prefWidth="390"
                          style="-fx-background-color: #1e1e1e;
                                 -fx-background-radius: 18;
                                 -fx-padding: 22;">

                        <Label text="Precio"
                               style="-fx-text-fill: #aaaaaa;
                                      -fx-font-size: 17px;" />

                        <Label fx:id="lblPrecio"
                               text="0"
                               style="-fx-text-fill: #f5c542;
                                      -fx-font-size: 31px;
                                      -fx-font-weight: bold;" />
                    </VBox>

                    <VBox alignment="CENTER"
                          spacing="8"
                          prefWidth="390"
                          style="-fx-background-color: #1e1e1e;
                                 -fx-background-radius: 18;
                                 -fx-padding: 22;">

                        <Label text="Stock"
                               style="-fx-text-fill: #aaaaaa;
                                      -fx-font-size: 17px;" />

                        <Label fx:id="lblStock"
                               text="0"
                               style="-fx-text-fill: #20d67b;
                                      -fx-font-size: 25px;
                                      -fx-font-weight: bold;" />
                    </VBox>

                </VBox>

            </HBox>

            <VBox spacing="14"
                  alignment="CENTER"
                  maxWidth="1050"
                  style="-fx-background-color: #1e1e1e;
                         -fx-background-radius: 24;
                         -fx-padding: 26;">

                <Label text="Descripcion"
                       style="-fx-text-fill: white;
                              -fx-font-size: 27px;
                              -fx-font-weight: bold;" />

                <Label fx:id="lblDescripcion"
                       wrapText="true"
                       maxWidth="980"
                       alignment="CENTER"
                       text="Descripcion general de la motocicleta."
                       style="-fx-text-fill: #d0d0d0;
                              -fx-font-size: 18px;
                              -fx-line-spacing: 4;" />
            </VBox>

            <HBox alignment="CENTER"
                  spacing="18">

                <Button text="Agregar al carrito"
                        onAction="#agregarCarrito"
                        prefWidth="220"
                        style="-fx-background-color: #f5c542;
                               -fx-text-fill: black;
                               -fx-font-size: 17px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 16;
                               -fx-padding: 14 24;
                               -fx-cursor: hand;" />

                <Button text="Ver carrito"
                        onAction="#abrirCarrito"
                        prefWidth="170"
                        style="-fx-background-color: #2f80ed;
                               -fx-text-fill: white;
                               -fx-font-size: 17px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 16;
                               -fx-padding: 14 24;
                               -fx-cursor: hand;" />

                <Button text="Favorito"
                        onAction="#agregarFavorito"
                        prefWidth="150"
                        style="-fx-background-color: #e63946;
                               -fx-text-fill: white;
                               -fx-font-size: 17px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 16;
                               -fx-padding: 14 24;
                               -fx-cursor: hand;" />

                <Button text="Volver"
                        onAction="#volverCatalogo"
                        prefWidth="140"
                        style="-fx-background-color: #2c2c2c;
                               -fx-text-fill: white;
                               -fx-font-size: 17px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 16;
                               -fx-padding: 14 24;
                               -fx-cursor: hand;" />

            </HBox>

        </VBox>

    </children>

</AnchorPane>
