<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.prueba.FavoritosController"
           style="-fx-background-color: linear-gradient(to bottom right, #050505, #101010, #181818);">

    <children>

        <!-- EFECTOS -->

        <Circle radius="240"
                translateX="-700"
                translateY="-350"
                fill="#ff4d6d"
                opacity="0.05"/>

        <Circle radius="180"
                translateX="750"
                translateY="420"
                fill="#d9ad26"
                opacity="0.04"/>

        <!-- CONTENIDO -->

        <BorderPane style="-fx-background-color: transparent;">

            <!-- TOP -->

            <top>

                <HBox alignment="CENTER_LEFT"
                      spacing="20"
                      style="
                            -fx-background-color: rgba(18,18,18,0.96);
                            -fx-padding: 20 35 20 35;
                            -fx-border-color: rgba(255,255,255,0.05);
                            -fx-border-width: 0 0 1 0;
                      ">

                    <effect>
                        <DropShadow color="#000000"
                                    radius="25"
                                    width="30"
                                    height="30"/>
                    </effect>

                    <!-- ICONO -->

                    <Label text="❤"
                           style="
                                -fx-text-fill: #ff4d6d;
                                -fx-font-size: 36;
                           "/>

                    <!-- TITULO -->

                    <VBox spacing="5">

                        <Label text="MOTOS FAVORITAS"
                               textFill="#ff4d6d">

                            <font>
                                <Font size="34"/>
                            </font>

                        </Label>

                        <Label text="Tus motocicletas favoritas premium"
                               style="
                                    -fx-text-fill: #aaaaaa;
                                    -fx-font-size: 14;
                               "/>

                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- BOTON VOLVER -->

                    <Button fx:id="btnVolver"
                            text="VOLVER"
                            onAction="#volverCatalogo"
                            style="
                                -fx-background-color: #242424;
                                -fx-text-fill: #d9ad26;
                                -fx-border-color: #d9ad26;
                                -fx-border-radius: 18;
                                -fx-background-radius: 18;
                                -fx-font-size: 14;
                                -fx-font-weight: bold;
                                -fx-padding: 12 24 12 24;
                                -fx-cursor: hand;
                            "/>

                </HBox>

            </top>

            <!-- CENTER -->

            <center>

                <ScrollPane fitToWidth="true"
                            pannable="true"
                            style="
                                -fx-background:#111111;
                                -fx-background-color: transparent;
                            ">

                    <content>

                        <VBox spacing="30">

                            <padding>
                                <Insets top="35"
                                        right="35"
                                        bottom="35"
                                        left="35"/>
                            </padding>

                            <!-- HEADER -->

                            <VBox spacing="10">

                                <HBox alignment="CENTER_LEFT"
                                      spacing="15">

                                    <Label text="LISTA DE FAVORITOS"
                                           style="
                                                -fx-text-fill: white;
                                                -fx-font-size: 38;
                                                -fx-font-weight: bold;
                                           "/>

                                    <Label text="🔥"
                                           style="-fx-font-size: 30;"/>

                                </HBox>

                                <Label text="Aquí aparecerán las motos que marques como favoritas."
                                       style="
                                            -fx-text-fill: #999999;
                                            -fx-font-size: 15;
                                       "/>

                            </VBox>

                            <!-- FLOWPANE -->

                            <FlowPane fx:id="flowFavoritos"
                                      alignment="TOP_CENTER"
                                      hgap="40"
                                      vgap="40"
                                      prefWrapLength="1650"/>

                        </VBox>

                    </content>

                </ScrollPane>

            </center>

            <!-- FOOTER -->

            <bottom>

                <HBox alignment="CENTER_RIGHT"
                      spacing="15"
                      style="
                            -fx-background-color: rgba(18,18,18,0.95);
                            -fx-padding: 18 35 18 35;
                            -fx-border-color: rgba(255,255,255,0.05);
                            -fx-border-width: 1 0 0 0;
                      ">

                    <Label text="MOTOSHOP FAVORITES SYSTEM"
                           style="
                                -fx-text-fill: #666666;
                                -fx-font-size: 12;
                           "/>

                </HBox>

            </bottom>

        </BorderPane>

    </children>

</StackPane>