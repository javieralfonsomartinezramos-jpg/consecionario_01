<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.prueba.CatalogoController"
           style="-fx-background-color: linear-gradient(to bottom right, #080808, #121212, #191919);">

    <children>

        <Circle fill="#f5c542"
                opacity="0.04"
                radius="250"
                translateX="-720"
                translateY="-360" />

        <Circle fill="#2f80ed"
                opacity="0.04"
                radius="220"
                translateX="760"
                translateY="410" />

        <BorderPane style="-fx-background-color: transparent;">

            <top>
                <VBox>

                    <HBox alignment="CENTER_LEFT"
                          spacing="20"
                          style="-fx-background-color: rgba(18,18,18,0.97);
                                 -fx-padding: 18 34 18 34;
                                 -fx-border-color: rgba(245,197,66,0.16);
                                 -fx-border-width: 0 0 1 0;">

                        <StackPane prefHeight="58"
                                   prefWidth="58"
                                   style="-fx-background-color: #242424;
                                          -fx-background-radius: 60;
                                          -fx-border-color: #f5c542;
                                          -fx-border-radius: 60;
                                          -fx-border-width: 2;">

                            <ImageView fitHeight="36"
                                       fitWidth="36"
                                       preserveRatio="true">
                                <image>
                                    <Image url="@images/user.png" />
                                </image>
                            </ImageView>
                        </StackPane>

                        <VBox spacing="3">
                            <Label text="MOTOSHOP"
                                   style="-fx-text-fill: #f5c542;
                                          -fx-font-size: 32;
                                          -fx-font-weight: bold;" />

                            <Label fx:id="lblUsuario"
                                   text="Usuario conectado"
                                   style="-fx-text-fill: #b8b8b8;
                                          -fx-font-size: 14;" />
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <HBox alignment="CENTER_LEFT"
                              spacing="10"
                              prefWidth="330"
                              style="-fx-background-color: #242424;
                                     -fx-background-radius: 16;
                                     -fx-border-color: #363636;
                                     -fx-border-radius: 16;
                                     -fx-padding: 8 14 8 14;">

                            <Label text="Buscar"
                                   style="-fx-text-fill: #f5c542;
                                          -fx-font-size: 13;
                                          -fx-font-weight: bold;" />

                            <TextField fx:id="txtBuscar"
                                       promptText="Nombre o marca"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-background-color: transparent;
                                              -fx-text-fill: white;
                                              -fx-prompt-text-fill: #777777;
                                              -fx-font-size: 14;" />
                        </HBox>

                        <Button text="TIENDA"
                                onAction="#abrirTienda"
                                style="-fx-background-color: #f5c542;
                                       -fx-text-fill: #111111;
                                       -fx-font-size: 13;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 14;
                                       -fx-padding: 11 22 11 22;
                                       -fx-cursor: hand;" />

                        <Button text="CARRITO"
                                onAction="#abrirCarrito"
                                style="-fx-background-color: #242424;
                                       -fx-text-fill: #f5c542;
                                       -fx-border-color: #f5c542;
                                       -fx-border-radius: 14;
                                       -fx-background-radius: 14;
                                       -fx-font-size: 13;
                                       -fx-font-weight: bold;
                                       -fx-padding: 11 22 11 22;
                                       -fx-cursor: hand;" />

                        <Button text="HISTORIAL"
                                onAction="#abrirHistorial"
                                style="-fx-background-color: #242424;
                                       -fx-text-fill: #f5c542;
                                       -fx-border-color: #f5c542;
                                       -fx-border-radius: 14;
                                       -fx-background-radius: 14;
                                       -fx-font-size: 13;
                                       -fx-font-weight: bold;
                                       -fx-padding: 11 22 11 22;
                                       -fx-cursor: hand;" />

                        <Button text="FAVORITOS"
                                onAction="#abrirFavoritos"
                                style="-fx-background-color: #e63946;
                                       -fx-text-fill: white;
                                       -fx-font-size: 13;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 14;
                                       -fx-padding: 11 22 11 22;
                                       -fx-cursor: hand;" />

                        <Button fx:id="btnAdmin"
                                text="ADMIN"
                                onAction="#abrirAdminPanel"
                                style="-fx-background-color: #2f80ed;
                                       -fx-text-fill: white;
                                       -fx-font-size: 13;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 14;
                                       -fx-padding: 11 22 11 22;
                                       -fx-cursor: hand;" />
                    </HBox>

                    <HBox alignment="CENTER_LEFT"
                          spacing="18"
                          style="-fx-background-color: rgba(24,24,24,0.97);
                                 -fx-padding: 15 34 15 34;
                                 -fx-border-color: rgba(255,255,255,0.05);
                                 -fx-border-width: 0 0 1 0;">

                        <Label text="Filtros"
                               style="-fx-text-fill: white;
                                      -fx-font-size: 18;
                                      -fx-font-weight: bold;" />

                        <Label text="Precio"
                               style="-fx-text-fill: #b8b8b8;
                                      -fx-font-size: 13;" />

                        <ComboBox fx:id="comboPrecio"
                                  onAction="#filtrarPrecio"
                                  prefWidth="190"
                                  style="-fx-background-color: #282828;
                                         -fx-background-radius: 12;" />

                        <Label text="Cilindraje"
                               style="-fx-text-fill: #b8b8b8;
                                      -fx-font-size: 13;" />

                        <ComboBox fx:id="comboCc"
                                  onAction="#filtrarCc"
                                  prefWidth="190"
                                  style="-fx-background-color: #282828;
                                         -fx-background-radius: 12;" />

                        <Button text="RESETEAR"
                                onAction="#resetearCatalogo"
                                style="-fx-background-color: #303030;
                                       -fx-text-fill: white;
                                       -fx-font-size: 13;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 12;
                                       -fx-padding: 9 20 9 20;
                                       -fx-cursor: hand;" />

                        <Region HBox.hgrow="ALWAYS" />

                        <Label text="Inventario actualizado"
                               style="-fx-text-fill: #777777;
                                      -fx-font-size: 12;" />
                    </HBox>
                </VBox>
            </top>

            <center>
                <ScrollPane fitToWidth="true"
                            pannable="true"
                            style="-fx-background: transparent;
                                   -fx-background-color: transparent;">

                    <content>
                        <VBox alignment="TOP_CENTER"
                              spacing="26">

                            <padding>
                                <Insets top="32"
                                        right="36"
                                        bottom="36"
                                        left="36" />
                            </padding>

                            <VBox alignment="CENTER"
                                  spacing="8">
                                <Label text="Catalogo de motocicletas"
                                       style="-fx-text-fill: white;
                                              -fx-font-size: 36;
                                              -fx-font-weight: bold;" />

                                <Label text="Explora productos, revisa detalles y agrega motos a favoritos o al carrito."
                                       style="-fx-text-fill: #a8a8a8;
                                              -fx-font-size: 15;" />
                            </VBox>

                            <FlowPane fx:id="flowPane"
                                      alignment="TOP_CENTER"
                                      hgap="28"
                                      vgap="28"
                                      prefWrapLength="1500" />
                        </VBox>
                    </content>
                </ScrollPane>
            </center>

        </BorderPane>

    </children>
</StackPane>
