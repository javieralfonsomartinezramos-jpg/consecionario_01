<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.prueba.HelloController"
           style="-fx-background-color: linear-gradient(to bottom right, #050505, #111111, #1a1a1a);">

   <children>

      <!-- EFECTOS -->

      <Circle radius="220"
              translateX="-600"
              translateY="-300"
              fill="#d9ad26"
              opacity="0.08"/>

      <Circle radius="180"
              translateX="600"
              translateY="320"
              fill="#d9ad26"
              opacity="0.05"/>

      <!-- PANEL -->

      <VBox alignment="CENTER"
            maxWidth="520"
            spacing="25"
            style="
                    -fx-background-color: rgba(20,20,20,0.95);
                    -fx-background-radius: 35;
                    -fx-border-color: rgba(217,173,38,0.25);
                    -fx-border-radius: 35;
                    -fx-padding: 55;
              ">

         <effect>
            <DropShadow color="#000000"
                        height="40"
                        radius="25"
                        width="40"/>
         </effect>

         <padding>
            <Insets top="50"
                    right="50"
                    bottom="50"
                    left="50"/>
         </padding>

         <!-- TITULO -->

         <Label text="MOTOSHOP"
                textFill="#d9ad26">

            <font>
               <Font size="50"/>
            </font>

         </Label>

         <Label text="La mejor tienda de motocicletas"
                textFill="#bbbbbb"
                style="-fx-font-size: 16px;"/>

         <!-- CORREO -->

         <VBox spacing="10">

            <Label text="Correo Electrónico"
                   textFill="#d9ad26">

               <font>
                  <Font size="18"/>
               </font>

            </Label>

            <TextField fx:id="txtCorreo"
                       prefHeight="55"
                       promptText="Ingresa tu correo"
                       style="
                                -fx-background-color: #2a2a2a;
                                -fx-text-fill: white;
                                -fx-prompt-text-fill: #888888;
                                -fx-background-radius: 15;
                                -fx-font-size: 16px;
                                -fx-padding: 10;
                           "/>

         </VBox>

         <!-- PASSWORD -->

         <VBox spacing="10">

            <Label text="Contraseña"
                   textFill="#d9ad26">

               <font>
                  <Font size="18"/>
               </font>

            </Label>

            <PasswordField fx:id="txtContrasena"
                           prefHeight="55"
                           promptText="Ingresa tu contraseña"
                           style="
                                    -fx-background-color: #2a2a2a;
                                    -fx-text-fill: white;
                                    -fx-prompt-text-fill: #888888;
                                    -fx-background-radius: 15;
                                    -fx-font-size: 16px;
                                    -fx-padding: 10;
                               "/>

         </VBox>

         <!-- REGISTRO -->

         <Hyperlink text="¿No tienes cuenta? Regístrate"
                    onAction="#abrirRegistro"
                    style="
                            -fx-text-fill: #d9ad26;
                            -fx-font-size: 15px;
                            -fx-border-color: transparent;
                       "/>

         <!-- BOTON LOGIN -->

         <Button text="INICIAR SESIÓN"
                 onAction="#iniciarSesion"
                 prefHeight="60"
                 prefWidth="320"
                 style="
                        -fx-background-color: #d9ad26;
                        -fx-text-fill: black;
                        -fx-font-size: 18px;
                        -fx-font-weight: bold;
                        -fx-background-radius: 18;
                        -fx-cursor: hand;
                    "/>

         <!-- BOTON SALIR -->

         <Button text="SALIR"
                 onAction="#salirPrograma"
                 prefHeight="55"
                 prefWidth="320"
                 style="
                        -fx-background-color: transparent;
                        -fx-border-color: #d9ad26;
                        -fx-border-width: 2;
                        -fx-border-radius: 18;
                        -fx-background-radius: 18;
                        -fx-text-fill: #d9ad26;
                        -fx-font-size: 17px;
                        -fx-font-weight: bold;
                        -fx-cursor: hand;
                    "/>

      </VBox>

   </children>

</StackPane>