<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.prueba.registerController"
           style="-fx-background-color: linear-gradient(to bottom right, #050505, #111111, #1a1a1a);">

    <children>

        <!-- EFECTOS DE FONDO -->

        <Circle radius="230"
                translateX="-620"
                translateY="-320"
                fill="#d9ad26"
                opacity="0.08"/>

        <Circle radius="180"
                translateX="620"
                translateY="330"
                fill="#d9ad26"
                opacity="0.05"/>

        <!-- PANEL CENTRAL -->

        <VBox alignment="CENTER"
              maxWidth="560"
              spacing="24"
              style="
                    -fx-background-color: rgba(20,20,20,0.95);
                    -fx-background-radius: 35;
                    -fx-border-color: rgba(217,173,38,0.25);
                    -fx-border-radius: 35;
                    -fx-padding: 55;
              ">

            <effect>
                <DropShadow color="#000000"
                            height="40"
                            radius="25"
                            width="40"/>
            </effect>

            <padding>
                <Insets top="50"
                        right="50"
                        bottom="50"
                        left="50"/>
            </padding>

            <!-- TITULO -->

            <Label text="REGISTRO"
                   textFill="#d9ad26">

                <font>
                    <Font size="48"/>
                </font>

            </Label>

            <Label text="Crea tu cuenta en MotoShop"
                   textFill="#aaaaaa"
                   style="-fx-font-size: 16px;"/>

            <!-- NOMBRE -->

            <VBox spacing="10">

                <Label text="Nombre"
                       textFill="#d9ad26">

                    <font>
                        <Font size="18"/>
                    </font>

                </Label>

                <TextField fx:id="txtNombre"
                           prefHeight="55"
                           promptText="Ingresa tu nombre"
                           style="
                                -fx-background-color: #2a2a2a;
                                -fx-text-fill: white;
                                -fx-prompt-text-fill: #888888;
                                -fx-background-radius: 15;
                                -fx-font-size: 16px;
                                -fx-padding: 10;
                           "/>

            </VBox>

            <!-- CORREO -->

            <VBox spacing="10">

                <Label text="Correo Electrónico"
                       textFill="#d9ad26">

                    <font>
                        <Font size="18"/>
                    </font>

                </Label>

                <TextField fx:id="txtCorreo"
                           prefHeight="55"
                           promptText="Ingresa tu correo"
                           style="
                                -fx-background-color: #2a2a2a;
                                -fx-text-fill: white;
                                -fx-prompt-text-fill: #888888;
                                -fx-background-radius: 15;
                                -fx-font-size: 16px;
                                -fx-padding: 10;
                           "/>

            </VBox>

            <!-- CONTRASEÑA -->

            <VBox spacing="10">

                <Label text="Contraseña"
                       textFill="#d9ad26">

                    <font>
                        <Font size="18"/>
                    </font>

                </Label>

                <PasswordField fx:id="txtContrasena"
                               prefHeight="55"
                               promptText="Ingresa tu contraseña"
                               style="
                                    -fx-background-color: #2a2a2a;
                                    -fx-text-fill: white;
                                    -fx-prompt-text-fill: #888888;
                                    -fx-background-radius: 15;
                                    -fx-font-size: 16px;
                                    -fx-padding: 10;
                               "/>

            </VBox>

            <!-- BOTON REGISTRAR -->

            <Button text="REGISTRAR"
                    onAction="#registrarUsuario"
                    prefHeight="60"
                    prefWidth="340"
                    style="
                        -fx-background-color: #d9ad26;
                        -fx-text-fill: black;
                        -fx-font-size: 18px;
                        -fx-font-weight: bold;
                        -fx-background-radius: 18;
                        -fx-cursor: hand;
                    "/>

            <!-- BOTONES ABAJO -->

            <Button text="VOLVER AL LOGIN"
                    onAction="#volverLogin"
                    prefHeight="55"
                    prefWidth="340"
                    style="
                        -fx-background-color: transparent;
                        -fx-border-color: #d9ad26;
                        -fx-border-width: 2;
                        -fx-border-radius: 18;
                        -fx-background-radius: 18;
                        -fx-text-fill: #d9ad26;
                        -fx-font-size: 16px;
                        -fx-font-weight: bold;
                        -fx-cursor: hand;
                    "/>

            <Button text="CERRAR"
                    onAction="#cerrarVentana"
                    prefHeight="55"
                    prefWidth="340"
                    style="
                        -fx-background-color: #8B0000;
                        -fx-text-fill: white;
                        -fx-font-size: 16px;
                        -fx-font-weight: bold;
                        -fx-background-radius: 18;
                        -fx-cursor: hand;
                    "/>

        </VBox>

    </children>

</StackPane>