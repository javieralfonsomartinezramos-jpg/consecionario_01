<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.prueba.HistorialController"
           style="-fx-background-color: linear-gradient(to bottom right, #080808, #121212, #191919);">

    <children>

        <Circle fill="#2f80ed"
                opacity="0.04"
                radius="250"
                translateX="-720"
                translateY="-360" />

        <Circle fill="#f5c542"
                opacity="0.035"
                radius="220"
                translateX="760"
                translateY="410" />

        <BorderPane style="-fx-background-color: transparent;">

            <top>
                <HBox alignment="CENTER_LEFT"
                      spacing="20"
                      style="-fx-background-color: rgba(18,18,18,0.97);
                             -fx-padding: 22 35 22 35;
                             -fx-border-color: rgba(245,197,66,0.16);
                             -fx-border-width: 0 0 1 0;">

                    <VBox spacing="4">
                        <Label text="HISTORIAL DE COMPRAS"
                               style="-fx-text-fill: #f5c542;
                                      -fx-font-size: 32;
                                      -fx-font-weight: bold;" />

                        <Label text="Solo aparecen las motos compradas y confirmadas"
                               style="-fx-text-fill: #b8b8b8;
                                      -fx-font-size: 14;" />
                    </VBox>

                    <Region HBox.hgrow="ALWAYS" />

                    <Button text="LIMPIAR"
                            onAction="#limpiarHistorial"
                            style="-fx-background-color: #303030;
                                   -fx-text-fill: white;
                                   -fx-font-size: 14;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 14;
                                   -fx-padding: 12 22 12 22;
                                   -fx-cursor: hand;" />

                    <Button text="VOLVER AL CATALOGO"
                            onAction="#volverCatalogo"
                            style="-fx-background-color: #242424;
                                   -fx-text-fill: #f5c542;
                                   -fx-border-color: #f5c542;
                                   -fx-border-radius: 14;
                                   -fx-background-radius: 14;
                                   -fx-font-size: 14;
                                   -fx-font-weight: bold;
                                   -fx-padding: 12 22 12 22;
                                   -fx-cursor: hand;" />
                </HBox>
            </top>

            <center>
                <ScrollPane fitToWidth="true"
                            pannable="true"
                            style="-fx-background: transparent;
                                   -fx-background-color: transparent;">

                    <content>
                        <VBox alignment="TOP_CENTER"
                              spacing="26">

                            <padding>
                                <Insets top="34"
                                        right="36"
                                        bottom="36"
                                        left="36" />
                            </padding>

                            <VBox alignment="CENTER"
                                  spacing="8">
                                <Label text="Compras recientes"
                                       style="-fx-text-fill: white;
                                              -fx-font-size: 34;
                                              -fx-font-weight: bold;" />

                                <Label text="Productos confirmados desde el carrito"
                                       style="-fx-text-fill: #a8a8a8;
                                              -fx-font-size: 15;" />
                            </VBox>

                            <FlowPane fx:id="flowHistorial"
                                      alignment="TOP_CENTER"
                                      hgap="28"
                                      vgap="28"
                                      prefWrapLength="1500" />
                        </VBox>
                    </content>
                </ScrollPane>
            </center>

        </BorderPane>

    </children>
</StackPane>
