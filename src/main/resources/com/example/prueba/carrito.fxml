<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.prueba.CarritoController"
           style="-fx-background-color: linear-gradient(to bottom right, #080808, #121212, #191919);">

    <children>

        <Circle fill="#f5c542"
                opacity="0.04"
                radius="250"
                translateX="-720"
                translateY="-360" />

        <Circle fill="#20d67b"
                opacity="0.035"
                radius="220"
                translateX="760"
                translateY="410" />

        <BorderPane style="-fx-background-color: transparent;">

            <top>
                <HBox alignment="CENTER_LEFT"
                      spacing="20"
                      style="-fx-background-color: rgba(18,18,18,0.97);
                             -fx-padding: 22 35 22 35;
                             -fx-border-color: rgba(245,197,66,0.16);
                             -fx-border-width: 0 0 1 0;">

                    <VBox spacing="4">
                        <Label text="CARRITO DE COMPRAS"
                               style="-fx-text-fill: #f5c542;
                                      -fx-font-size: 32;
                                      -fx-font-weight: bold;" />

                        <Label text="Revisa tus productos antes de confirmar la compra"
                               style="-fx-text-fill: #b8b8b8;
                                      -fx-font-size: 14;" />
                    </VBox>

                    <Region HBox.hgrow="ALWAYS" />

                    <Button text="VOLVER AL CATALOGO"
                            onAction="#volverCatalogo"
                            style="-fx-background-color: #242424;
                                   -fx-text-fill: #f5c542;
                                   -fx-border-color: #f5c542;
                                   -fx-border-radius: 14;
                                   -fx-background-radius: 14;
                                   -fx-font-size: 14;
                                   -fx-font-weight: bold;
                                   -fx-padding: 12 22 12 22;
                                   -fx-cursor: hand;" />
                </HBox>
            </top>

            <center>
                <ScrollPane fitToWidth="true"
                            pannable="true"
                            style="-fx-background: transparent;
                                   -fx-background-color: transparent;">

                    <content>
                        <VBox fx:id="contenedorCarrito"
                              alignment="TOP_CENTER"
                              spacing="18">

                            <padding>
                                <Insets top="34"
                                        right="36"
                                        bottom="34"
                                        left="36" />
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </center>

            <bottom>
                <HBox alignment="CENTER_RIGHT"
                      spacing="18"
                      style="-fx-background-color: rgba(18,18,18,0.97);
                             -fx-padding: 20 35 20 35;
                             -fx-border-color: rgba(255,255,255,0.06);
                             -fx-border-width: 1 0 0 0;">

                    <Label text="Total de la compra"
                           style="-fx-text-fill: #b8b8b8;
                                  -fx-font-size: 14;" />

                    <Label fx:id="lblTotal"
                           text="TOTAL: 0"
                           style="-fx-text-fill: #f5c542;
                                  -fx-font-size: 28;
                                  -fx-font-weight: bold;" />

                    <Region HBox.hgrow="ALWAYS" />

                    <Button text="VACIAR"
                            onAction="#vaciarCarrito"
                            style="-fx-background-color: #303030;
                                   -fx-text-fill: white;
                                   -fx-font-size: 14;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 14;
                                   -fx-padding: 12 24 12 24;
                                   -fx-cursor: hand;" />

                    <Button text="COMPRAR TODO"
                            onAction="#comprarTodo"
                            style="-fx-background-color: #f5c542;
                                   -fx-text-fill: #111111;
                                   -fx-font-size: 14;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 14;
                                   -fx-padding: 12 28 12 28;
                                   -fx-cursor: hand;" />
                </HBox>
            </bottom>

        </BorderPane>

    </children>
</StackPane>
