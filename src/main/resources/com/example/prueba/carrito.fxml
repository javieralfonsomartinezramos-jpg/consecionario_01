<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.prueba.CarritoController"
           style="-fx-background-color: linear-gradient(to bottom right, #050505, #111111, #1a1a1a);">

    <children>

        <!-- EFECTOS -->

        <Circle radius="250"
                translateX="-700"
                translateY="-350"
                fill="#d9ad26"
                opacity="0.05"/>

        <Circle radius="180"
                translateX="750"
                translateY="420"
                fill="#d9ad26"
                opacity="0.04"/>

        <!-- CONTENIDO -->

        <BorderPane style="-fx-background-color: transparent;">

            <!-- ========================================= -->
            <!-- TOP BAR -->
            <!-- ========================================= -->

            <top>

                <HBox alignment="CENTER_LEFT"
                      spacing="20"
                      style="
                            -fx-background-color: rgba(20,20,20,0.95);
                            -fx-padding: 20 35 20 35;
                            -fx-border-color: rgba(217,173,38,0.15);
                            -fx-border-width: 0 0 1 0;
                      ">

                    <Label text="🛒"
                           style="-fx-font-size: 34;"/>

                    <VBox spacing="5">

                        <Label text="CARRITO DE COMPRAS"
                               textFill="#d9ad26">

                            <font>
                                <Font size="34"/>
                            </font>

                        </Label>

                        <Label text="Tus motocicletas seleccionadas"
                               style="
                                    -fx-text-fill: #aaaaaa;
                                    -fx-font-size: 14;
                               "/>

                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- BOTON VOLVER -->

                    <Button text="VOLVER"
                            onAction="#volverCatalogo"
                            style="
                                -fx-background-color: #242424;
                                -fx-text-fill: #d9ad26;
                                -fx-border-color: #d9ad26;
                                -fx-border-radius: 18;
                                -fx-background-radius: 18;
                                -fx-font-size: 14;
                                -fx-font-weight: bold;
                                -fx-padding: 12 24 12 24;
                                -fx-cursor: hand;
                            "/>

                </HBox>

            </top>

            <!-- ========================================= -->
            <!-- CENTER -->
            <!-- ========================================= -->

            <center>

                <ScrollPane fitToWidth="true"
                            pannable="true"
                            style="
                                -fx-background:#111111;
                                -fx-background-color: transparent;
                            ">

                    <content>

                        <VBox spacing="25"
                              fx:id="contenedorCarrito">

                            <padding>
                                <Insets top="30"
                                        right="35"
                                        bottom="30"
                                        left="35"/>
                            </padding>

                        </VBox>

                    </content>

                </ScrollPane>

            </center>

            <!-- ========================================= -->
            <!-- BOTTOM -->
            <!-- ========================================= -->

            <bottom>

                <HBox alignment="CENTER_RIGHT"
                      spacing="20"
                      style="
                            -fx-background-color: rgba(18,18,18,0.95);
                            -fx-padding: 20 35 20 35;
                            -fx-border-color: rgba(255,255,255,0.05);
                            -fx-border-width: 1 0 0 0;
                      ">

                    <!-- TOTAL -->

                    <Label fx:id="lblTotal"
                           text="TOTAL: $0"
                           style="
                                -fx-text-fill: #d9ad26;
                                -fx-font-size: 28;
                                -fx-font-weight: bold;
                           "/>

                    <!-- VACIAR -->

                    <Button text="VACIAR"
                            onAction="#vaciarCarrito"
                            style="
                                -fx-background-color: #2a2a2a;
                                -fx-text-fill: white;
                                -fx-font-size: 14;
                                -fx-font-weight: bold;
                                -fx-background-radius: 18;
                                -fx-padding: 12 24 12 24;
                                -fx-cursor: hand;
                            "/>

                    <!-- COMPRAR -->

                    <Button text="COMPRAR TODO"
                            onAction="#comprarTodo"
                            style="
                                -fx-background-color: linear-gradient(to right, #d9ad26, #f0c94d);
                                -fx-text-fill: black;
                                -fx-font-size: 15;
                                -fx-font-weight: bold;
                                -fx-background-radius: 18;
                                -fx-padding: 12 28 12 28;
                                -fx-cursor: hand;
                            "/>

                </HBox>

            </bottom>

        </BorderPane>

    </children>

</StackPane>