<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<Pane prefHeight="1200.0" prefWidth="1920.0" style="-fx-background-color: #000000;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.prueba.HelloController">

   <children>

      <!-- TITULO -->

      <Label layoutX="700.0" layoutY="180.0" text="MOTOSHOP" textFill="#d9ad26">

         <font>
            <Font size="72.0" />
         </font>

      </Label>

      <!-- CORREO -->

      <Label layoutX="690.0" layoutY="400.0" text="Correo Electrónico" textFill="#d9ad26">

         <font>
            <Font size="28.0" />
         </font>

      </Label>

      <TextField fx:id="txtCorreo" layoutX="690.0" layoutY="450.0" prefHeight="70.0" prefWidth="540.0" style="-fx-font-size: 24px; -fx-background-radius: 15;" />

      <!-- CONTRASEÑA -->

      <Label layoutX="690.0" layoutY="560.0" text="Contraseña" textFill="#d9ad26">

         <font>
            <Font size="28.0" />
         </font>

      </Label>

      <PasswordField fx:id="txtContrasena" layoutX="690.0" layoutY="610.0" prefHeight="70.0" prefWidth="540.0" style="-fx-font-size: 24px; -fx-background-radius: 15;" />

      <!-- BOTON -->

      <Button layoutX="800.0" layoutY="797.0" mnemonicParsing="false" onAction="#iniciarSesion" prefHeight="80.0" prefWidth="320.0" style="-fx-background-color: d9ad26; -fx-background-radius: 25;" text="INICIAR SESIÓN">

         <font>
            <Font size="28.0" />
         </font>

      </Button>
      <Label layoutX="760.0" layoutY="717.0" text="¿no tienes cuenta?" textFill="#d9ad26">
         <font>
            <Font size="24.0" />
         </font>
      </Label>
      <Label accessibleRole="BUTTON" layoutX="994.0" layoutY="717.0" text="registrate" textFill="#d9ad26">
         <font>
            <Font size="24.0" />
         </font>
      </Label>

   </children>

</Pane>
