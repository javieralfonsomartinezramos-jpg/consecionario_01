<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<Pane prefHeight="1200.0"
      prefWidth="1920.0"
      style="-fx-background-color: #000000;"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.prueba.HelloController">

   <children>

      <!-- TITULO -->

      <Label layoutX="700.0"
             layoutY="180.0"
             text="MOTOSHOP"
             textFill="WHITE">

         <font>
            <Font size="72.0"/>
         </font>

      </Label>

      <!-- CORREO -->

      <Label layoutX="690.0"
             layoutY="400.0"
             text="Correo Electrónico"
             textFill="WHITE">

         <font>
            <Font size="28.0"/>
         </font>

      </Label>

      <TextField fx:id="txtCorreo"
                 layoutX="690.0"
                 layoutY="450.0"
                 prefHeight="70.0"
                 prefWidth="540.0"
                 style="-fx-font-size: 24px; -fx-background-radius: 15;" />

      <!-- CONTRASEÑA -->

      <Label layoutX="690.0"
             layoutY="560.0"
             text="Contraseña"
             textFill="WHITE">

         <font>
            <Font size="28.0"/>
         </font>

      </Label>

      <PasswordField fx:id="txtContrasena"
                     layoutX="690.0"
                     layoutY="610.0"
                     prefHeight="70.0"
                     prefWidth="540.0"
                     style="-fx-font-size: 24px; -fx-background-radius: 15;" />

      <!-- BOTON -->

      <Button layoutX="800.0"
              layoutY="760.0"
              mnemonicParsing="false"
              onAction="#iniciarSesion"
              prefHeight="80.0"
              prefWidth="320.0"
              style="-fx-background-color: #FF5000; -fx-background-radius: 25;"
              text="INICIAR SESIÓN"
              textFill="WHITE">

         <font>
            <Font size="28.0"/>
         </font>

      </Button>

   </children>

</Pane>
